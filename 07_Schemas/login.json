{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "user": {
      "type": "string",
      "format": "email"
    },
    "password": {
      "type": "string",
      "pattern": "^(?=.*[A-Z])(?=.*[!@#$%^&*()-_=+{}|;:',<.>?])(.{8,})$"
    }
  },
  "required": ["user", "password"]
}