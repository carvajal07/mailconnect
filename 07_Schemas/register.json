{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "phone": {
      "type": "string",
      "pattern": "^3\\d{9}$"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "company": {
      "type": "string",
      "minLength": 1
    },
    "companyTin": {
      "type": "integer"
    },
    "password": {
      "type": "string",
      "pattern": "^(?=.*[A-Z])(?=.*[!@#$%^&*()-_=+{}|;:',<.>?])(.{8,})$"
    }
  },
  "required": ["name", "phone", "email", "company", "companyTin", "password"]
}