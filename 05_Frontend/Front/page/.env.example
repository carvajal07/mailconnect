# URL base de la API de MailConnect. Copia este archivo como ".env" y ajusta.
# IMPORTANTE: los endpoints del front son relativos (/login, /create-template, ...),
# así que la base debe incluir todo lo anterior. Si tus recursos en API Gateway
# están bajo "/api", la base termina en "/api".
#   Producción (dominio propio):  https://api.mailconnect.com.co/V1/api
#   Stage de pruebas:             https://mtgt9qpb77.execute-api.us-east-1.amazonaws.com/Test/api
# Si tu API NO usa el prefijo "/api", quítalo (ej. https://api.mailconnect.com.co/V1).
VITE_API_BASE_URL=https://api.mailconnect.com.co/V1/api

# Modo de autenticación DEMO (solo desarrollo).
# Con VITE_AUTH_MOCK=true el login funciona SIN backend: cualquier credencial
# no vacía inicia sesión y entra a /panel. Útil mientras la API real no está lista.
# Credencial sugerida: demo@mailconnect.com.co / Demo1234 (en mock sirve cualquiera).
# NO lo actives en producción.
VITE_AUTH_MOCK=false
