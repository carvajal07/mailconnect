# URL base de la API de MailConnect. Copia este archivo como ".env" y ajusta.
# Los endpoints del front son relativos y agrupados por módulo (ej. /Security/Login,
# /Template/Create-template, /Campaign/Prefirm-url, /Report), así que la base es
# solo hasta /V1 (sin las rutas de módulo ni /api).
VITE_API_BASE_URL=https://api.mailconnect.com.co/V1

# Modo de autenticación DEMO (solo desarrollo).
# Con VITE_AUTH_MOCK=true el login funciona SIN backend: cualquier credencial
# no vacía inicia sesión y entra a /panel. Útil mientras la API real no está lista.
# Credencial sugerida: demo@mailconnect.com.co / Demo1234 (en mock sirve cualquiera).
# NO lo actives en producción.
VITE_AUTH_MOCK=false
